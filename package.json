{
  "name": "priority-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for Priority ERP OData API",
  "type": "module",
  "license": "MIT",
  "author": "Community",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropic-community/priority-mcp-server"
  },
  "keywords": ["mcp", "priority", "erp", "odata", "claude"],
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "priority-mcp-server": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": ["dist"],
  "scripts": {
    "dev": "node --experimental-strip-types src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "inspect": "npx @modelcontextprotocol/inspector node --experimental-strip-types src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@hono/node-server": "^1.13.0",
    "hono": "^4.7.0",
    "pino": "^9.6.0",
    "undici": "^7.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
